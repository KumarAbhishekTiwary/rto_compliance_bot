# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Corporate Proxy (optional)
# HTTPS_PROXY=http://proxy.company.com:8080
# HTTP_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1

# SSL (dev only — set true if behind ZScaler/BlueCoat)
DISABLE_SSL_VERIFY=false
# REQUESTS_CA_BUNDLE=C:\path\to\ca_bundle.pem

# Gmail SMTP (optional — works in mock mode without it)
# GMAIL_USER=your.email@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# GMAIL_IMAP_ENABLED=true
# EMAIL_POLL_SECONDS=30

# Reminder intervals
# Minutes override hours when greater than 0.
# The older SLA_* values are still supported as fallback defaults.
SLA_HOURS=24
SLA_MINUTES=1
TEAMS_REMINDER_HOURS=24
TEAMS_REMINDER_MINUTES=1
EMAIL_REMINDER_HOURS=24
EMAIL_REMINDER_MINUTES=1

# MS Teams / Graph API (Phase 6 migration)
# USE_TEAMS=false
# GRAPH_TOKEN=your-graph-token
